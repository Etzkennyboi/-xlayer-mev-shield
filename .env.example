# OKX API Credentials (Required for onchainOS)
OKX_API_KEY=your-api-key
OKX_SECRET_KEY=your-secret-key
OKX_PASSPHRASE=your-passphrase

# X Layer RPC URL (Optional — defaults to xlayer.drpc.org)
# Override with your own node or a private RPC for better reliability
XLAYER_RPC_URL=https://xlayer.drpc.org

# Server
PORT=3000
